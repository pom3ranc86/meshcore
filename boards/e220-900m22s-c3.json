{
  "build": {
    "arduino": {
      "ldscript": "esp32c3_out.ld",
      "partitions": "default.csv",
      "memory_type": "qio_qspi"
    },
    "core": "esp32",
    "extra_flags": [
      "-DARDUINO_AIRM2M_CORE_ESP32C3",
      "-DBOARD_HAS_PSRAM",
      "-DARDUINO_USB_CDC_ON_BOOT=1",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1",
      "-DARDUINO_USB_MODE=1"
    ],
    "f_cpu": "160000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "mcu": "esp32c3",
    "variant": "airm2m_core_esp32c3"
  },
  "connectivity": [
    "wifi",
    "bluetooth"
  ],
  "debug": {
    "openocd_target": "esp32c3.cfg"
  },
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "name": "ESP32-C3 + Ebyte E220-900M22S",
  "upload": {
    "flash_size": "4MB",
    "maximum_ram_size": 262144,
    "maximum_size": 4194304,
    "use_1200bps_touch": true,
    "wait_for_upload_port": true,
    "require_upload_port": true,
    "speed": 460800
  },
  "url": "https://www.cdebyte.com/products/E220-900M22S",
  "vendor": "Chengdu Ebyte Electronic Technology Co., Ltd"
}